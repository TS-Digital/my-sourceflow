# Supabase — copy this file to .env.local and fill in your project values.
# Find these in: https://supabase.com/dashboard → Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role — used server-side only to look up auth.users emails
# Find in: Supabase Dashboard → Project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — https://resend.com → API Keys
RESEND_API_KEY=re_your_key_here

# The "from" address for outgoing emails.
# Must be a verified domain in Resend (or use onboarding@resend.dev for testing).
RESEND_FROM_EMAIL=onboarding@resend.dev

# Your app's public URL (used to build links in admin notification emails)
NEXT_PUBLIC_APP_URL=https://your-domain.com
